# 复制本文件为 .env，然后填入你的配置

# ── API ──────────────────────────────────────────────────────────────────
# 必填：你的 API Key
API_KEY=your-api-key-here

# 可选：API 地址，不填则使用默认值
BASE_URL=https://api.scnet.cn/api/llm/v1

# 可选：Cookie 头（API 网关鉴权）
COOKIE=SKIP_SESSION_UPDATE=1775035134158

# 可选：使用的模型，不填则用默认值
MODEL=MiniMax-M2.5

# ── Embedding（本地模型，无需 API Key）────────────────────────────────────
# 首次启动会自动下载模型（~120MB），后续从本地缓存加载
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
